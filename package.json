{
  "name": "nawgati-insurance-dashboard-service",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "build": "babel src -d build",
    "start": "nodemon",
    "serve": "yarn run build && node build",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "clean": "rm -rf node_modules",
    "nuke": "rm -rf node_modules yarn.lock package-lock.json"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js",
    "exec": "babel-node src/index.js"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.9.5",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.0",
    "@babel/node": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@biomejs/biome": "^1.9.4",
    "nodemon": "^3.1.9"
  }
}
